{
  "name": "pennyscan-backend",
  "version": "2.0.0",
  "description": "PennyScan backend API and job queue",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "ts-node scripts/seed.ts",
    "jobs:scrape": "ts-node scripts/scrape-deals.ts",
    "jobs:decay": "ts-node scripts/decay-scores.ts"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "@prisma/client": "^5.8.0",
    "redis": "^4.6.0",
    "bull": "^4.11.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "cheerio": "^1.0.0-rc.12",
    "haversine-distance": "^1.2.1",
    "@mapbox/mapbox-sdk": "^0.15.0",
    "express-async-errors": "^3.1.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@testing-library/node": "^20.0.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^2.0.12",
    "prettier": "^3.1.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "prisma": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
