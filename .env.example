# Environment variables template
# Copy to .env.local (frontend) or .env (backend)

# Database
DATABASE_URL="postgresql://pennyscan:dev_password@localhost:5432/pennyscan"

# Redis
REDIS_URL="redis://localhost:6379"

# API
PORT=3001
API_SECRET="your-secret-key-here"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# External APIs
MAPBOX_TOKEN="pk.your-mapbox-token-here"

# Store APIs (optional)
WALMART_API_KEY=""
TARGET_API_KEY=""
HOME_DEPOT_API_KEY=""

# Feature flags
ENABLE_DG_SCRAPER=true
ENABLE_DT_SCRAPER=true
ENABLE_HD_SCRAPER=true
ENABLE_LOWES_SCRAPER=true
ENABLE_WALMART_SCRAPER=true
ENABLE_TARGET_SCRAPER=true
ENABLE_COMMUNITY_SUBMISSIONS=true

# Job scheduling (milliseconds)
JOB_INTERVAL_SCRAPE=3600000          # 1 hour
JOB_INTERVAL_DECAY=3600000           # 1 hour
JOB_INTERVAL_CLEANUP=86400000        # 24 hours
JOB_INTERVAL_REFRESH_STORES=604800000 # 7 days

# Logging
LOG_LEVEL=debug

# Frontend (for Next.js)
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your-mapbox-token-here"
NEXT_PUBLIC_GA_ID=""
